/* ════════════════════════════════════════════════════════════════════
   Coro Pacem Deus — Reglas de seguridad de Realtime Database
   ════════════════════════════════════════════════════════════════════

   Reemplaza las reglas de Test Mode (que vencen) por estas reglas.

   FILOSOFÍA:
     La app es estática (GitHub Pages) y NO autentica usuarios. Las
     reglas se basan en validación estructural — solo se aceptan
     escrituras a paths con formato exacto y payloads acotados.

     • DENIEGAN por default cualquier path no listada.
     • PERMITEN lectura pública en las paths que la app necesita leer
       (overrides + history + setlist).
     • PERMITEN escritura validando: formato del ID (cpd-XXX o cps-XXX),
       formato de la fecha/timestamp, tipo del valor, y tamaño máximo.

   SOPORTE PARA AMBOS CANCIONEROS:
     • cpd-XXX → Cancionero Dominical (cpd-001 a cpd-117 actualmente)
     • cps-XXX → Cancionero Semana Santa (si vuelve a usarse)
     • Si algún día superas cpd-999, ampliar el regex a {3,4}.

   PARA APLICAR ESTAS REGLAS:
     1. Abrir https://console.firebase.google.com/
     2. Proyecto: CoroPacemDeusDominical
     3. Realtime Database → pestaña "Reglas"
     4. Borrar todo el contenido actual
     5. Pegar el JSON de abajo (SIN ESTOS COMENTARIOS — Firebase no los acepta)
     6. Click "Publicar"

   ════════════════════════════════════════════════════════════════════ */
{
  "rules": {
    ".read": false,
    ".write": false,

    "chord-overrides": {
      ".read": true,
      "$cpdId": {
        ".write": "$cpdId.matches(/^cp[ds]-[0-9]{3}$/)",
        ".validate": "newData.isString() && newData.val().length <= 50000"
      }
    },

    "lyrics-overrides": {
      ".read": true,
      "$cpdId": {
        ".write": "$cpdId.matches(/^cp[ds]-[0-9]{3}$/)",
        ".validate": "newData.isString() && newData.val().length <= 100000"
      }
    },

    "chord-history": {
      ".read": true,
      "$cpdId": {
        "$timestamp": {
          ".write": "$cpdId.matches(/^cp[ds]-[0-9]{3}$/) && $timestamp.matches(/^[0-9]{10,16}$/)",
          ".validate": "newData.hasChildren(['content', 'savedAt']) && newData.child('content').isString() && newData.child('content').val().length <= 50000 && newData.child('savedAt').isNumber()"
        }
      }
    },

    "lyrics-history": {
      ".read": true,
      "$cpdId": {
        "$timestamp": {
          ".write": "$cpdId.matches(/^cp[ds]-[0-9]{3}$/) && $timestamp.matches(/^[0-9]{10,16}$/)",
          ".validate": "newData.hasChildren(['content', 'savedAt']) && newData.child('content').isString() && newData.child('content').val().length <= 100000 && newData.child('savedAt').isNumber()"
        }
      }
    },

    "setlist": {
      ".read": true,
      "$dateKey": {
        ".write": "$dateKey.matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)",
        "$slotId": {
          ".validate": "!newData.exists() || (newData.hasChildren(['cpd', 'title']) && newData.child('cpd').val().matches(/^cp[ds]-[0-9]{3}$/) && newData.child('title').isString() && newData.child('title').val().length <= 200)"
        }
      }
    }
  }
}
